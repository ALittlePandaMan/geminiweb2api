# Path to the mounted cookie file inside the container.
GEMINI_GATEWAY_COOKIE_PATH=/app/cookies/cookies.json

# These values are kept for configuration clarity.
# The bundled Docker image currently starts uvicorn on 0.0.0.0:9090 directly.
GEMINI_GATEWAY_HOST=0.0.0.0
GEMINI_GATEWAY_PORT=9090

# Default model used when the incoming request omits "model".
GEMINI_GATEWAY_MODEL_DEFAULT=gemini-3-pro

# Log level for the gateway internals.
GEMINI_GATEWAY_LOG_LEVEL=INFO

# Per-request timeout in seconds.
GEMINI_GATEWAY_REQUEST_TIMEOUT=300

# Directory used to persist cookie cache / refresh state.
GEMINI_COOKIE_PATH=/app/docker-data

# Leave empty or unset to allow anonymous access.
# Set a value to require: Authorization: Bearer <your-key>
GEMINI_GATEWAY_API_KEY=sk-123456789
